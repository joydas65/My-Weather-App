    "audit:consistency": "node scripts/audit-consistency.mjs",
    "check": "pnpm lint && pnpm test && pnpm audit:consistency"
  },
  "dependencies": {
    "chart.js": "4.5.1",
    "clsx": "2.1.1",
    "lucide-react": "1.23.0",
    "next": "16.2.10",
    "react": "19.2.7",
    "react-chartjs-2": "5.3.1",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@eslint/eslintrc": "3.3.5",
    "@tailwindcss/postcss": "4.3.2",
    "@testing-library/react": "16.3.2",
    "@types/node": "26.1.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.10",
    "postcss": "8.5.16",
    "tailwindcss": "4.3.2",
    "typescript": "6.0.3",
    "vitest": "4.1.9"
  },
  "engines": {
    "node": ">=20.9.0"
