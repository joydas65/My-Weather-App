{
  "name": "my-weather-app",
  "version": "0.1.0",
  "private": true,
  "description": "A Next.js weather dashboard with geolocation, forecasts, and charted weather trends.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
